# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (majburiy)
DATABASE_URL=postgresql://username:password@localhost:5432/youtube_uzbek

# Anthropic API (premium tarjima va post generatsiya uchun majburiy)
ANTHROPIC_API_KEY=sk-ant-...

# Session (ishlab chiqarishda majburiy — tasodifiy uzun string)
SESSION_SECRET=your-very-long-random-secret-here

# Admin panel paroli (majburiy)
ADMIN_PASSWORD=your-admin-password
