# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (majburiy)
DATABASE_URL=postgresql://username:password@localhost:5432/youtube_uzbek

# Anthropic API (premium tarjima va post generatsiya uchun majburiy)
ANTHROPIC_API_KEY=sk-ant-...

# Session (ishlab chiqarishda majburiy — tasodifiy uzun string)
SESSION_SECRET=your-very-long-random-secret-here

# Admin panel paroli (majburiy)
ADMIN_PASSWORD=your-admin-password

# Gmail SMTP (OTP email yuborish uchun ixtiyoriy — yo'q bo'lsa OTP o'tkazib yuboriladi)
# Gmail → Sozlamalar → Xavfsizlik → "Ilovalar uchun parol" dan oling
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google Analytics 4 (ixtiyoriy)
# analytics.google.com → Stream → Measurement ID
GA4_ID=G-XXXXXXXXXX
